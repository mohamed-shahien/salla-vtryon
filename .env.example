# Salla
SALLA_CLIENT_ID=your_salla_client_id
SALLA_CLIENT_SECRET=your_salla_client_secret
SALLA_WEBHOOK_SECRET=your_salla_webhook_secret
SALLA_APP_ID=your_salla_app_id
SALLA_API_BASE_URL=https://api.salla.dev
SALLA_ADMIN_API_BASE_URL=https://api.salla.dev/admin/v2
SALLA_ACCOUNTS_BASE_URL=https://accounts.salla.sa

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/virtual_tryon

# Replicate
REPLICATE_API_TOKEN=your_replicate_api_token
REPLICATE_MODEL=cuuupid/idm-vton
REPLICATE_MODEL_VERSION=
REPLICATE_POLL_INTERVAL_MS=3000
REPLICATE_TIMEOUT_MS=120000

# Bunny
BUNNY_STORAGE_ZONE=your_bunny_storage_zone
BUNNY_API_KEY=your_bunny_api_key
BUNNY_CDN_URL=https://your-zone.b-cdn.net

# App
APP_URL=http://localhost:5173
API_URL=https://your-public-api.ngrok-free.app
DASHBOARD_URL=http://localhost:5173
ENCRYPTION_KEY=replace_with_a_secure_32_char_key
JOB_PROCESSOR_ENABLED=true
JOB_PROCESSOR_POLL_INTERVAL_MS=5000
JOB_PROCESSOR_BATCH_SIZE=5
NODE_ENV=development
PORT=3001
SALLA_CALLBACK_URL=
SALLA_OAUTH_SCOPES="offline_access settings.read products.read products.read_write"
