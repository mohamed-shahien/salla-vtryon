{
  "name": "salla-vtryon",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @virtual-tryon/api dev",
    "dev:dashboard": "pnpm --filter @virtual-tryon/dashboard dev",
    "dev:widget": "pnpm --filter @virtual-tryon/widget dev",
    "build": "pnpm --filter @virtual-tryon/shared-types build && pnpm --filter @virtual-tryon/api build && pnpm --filter @virtual-tryon/dashboard build && pnpm --filter @virtual-tryon/widget build",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @virtual-tryon/api build && pnpm --filter @virtual-tryon/dashboard exec tsc -b && pnpm --filter @virtual-tryon/shared-types build",
    "supabase:status": "pnpm dlx supabase status",
    "supabase:start": "pnpm dlx supabase start",
    "supabase:stop": "pnpm dlx supabase stop",
    "supabase:db:push": "pnpm dlx supabase db push"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "replicate": "^1.4.0",
    "zod": "^3.25.76"
  }
}
